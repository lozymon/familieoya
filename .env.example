# ── JWT (RS256) ────────────────────────────────────────────────────────────────
# Generate:
#   openssl genrsa -out auth_private.pem 2048
#   openssl rsa -in auth_private.pem -pubout -out auth_public.pem
# Paste the PEM contents below, replacing literal newlines with \n
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Internal service secret ────────────────────────────────────────────────────
# Any 32-byte random hex string. Used by InternalApiGuard on all /internal/* endpoints.
# Generate: openssl rand -hex 32
INTERNAL_SECRET=change-me-in-production

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Databases ─────────────────────────────────────────────────────────────────
# auth-service
DATABASE_URL=postgres://auth:auth@localhost:5432/auth_db

# ── Service URLs (used by api-gateway) ────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
HOUSEHOLD_SERVICE_URL=http://localhost:3002   # added in Phase 2

# ── Stripe (added in Phase 10) ────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FREE=price_...
# STRIPE_PRICE_PRO_NOK=price_...
# STRIPE_PRICE_PRO_EUR=price_...
# STRIPE_PRICE_FAMILY_NOK=price_...
# STRIPE_PRICE_FAMILY_EUR=price_...
