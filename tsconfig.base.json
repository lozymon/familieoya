{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "@familieoya/contracts": ["libs/contracts/src/index.ts"],
      "@familieoya/common": ["libs/common/src/index.ts"],
      "@familieoya/testing": ["libs/testing/src/index.ts"],
      "@familieoya/ui": ["libs/ui/src/index.ts"],
      "@familieoya/api-client": ["libs/api-client/src/index.ts"],
      "@familieoya/i18n": ["libs/i18n/src/index.ts"]
    }
  }
}
